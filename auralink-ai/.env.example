# AuraLink AI - Environment variables
# Copy to .env and fill in values

# === Backend (FastAPI) ===
# APP_BASE_URL=http://localhost:8000
# FRONTEND_URL=http://localhost:3000

# === Vision (Gemini or OpenAI) ===
VISION_PROVIDER=gemini
GEMINI_API_KEY=
# OPENAI_API_KEY=

# === OCR (Google Cloud Vision) ===
# GCP_VISION_CREDENTIALS_JSON=

# === Database (Supabase) ===
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# === Redis (Celery broker) ===
REDIS_URL=redis://localhost:6379/0

# === Clerk (JWT verification for protected routes) ===
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# === Shopify OAuth ===
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# === Optional ===
# DEBUG=false
# BRANDS_DB_PATH=

# === Production: when CLERK_SECRET_KEY is set, protected routes require
#     Authorization: Bearer <session_token>. Frontend should use Clerk's
#     getToken() and pass it in API requests.
