# =============================================================================
# SyncLyst Backend - Production environment configuration
# Copy to .env and set values. Never commit .env to version control.
# =============================================================================
#
# DUMMY RUN (see the flow without connecting anything):
# - Leave SUPABASE_URL and SUPABASE_SERVICE_KEY empty (or omit them).
# - Leave GEMINI_API_KEY and OPENAI_API_KEY empty for dummy vision extraction.
# - Set CORS_ORIGINS= or CORS_ORIGINS=* (or add http://localhost:3000) for local frontend.
# Then: start backend (uvicorn), start frontend, open Try product scan → upload/capture
#       → you get dummy extraction → Save as draft → list products (in-memory). No DB or API keys needed.
#
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (PostgreSQL)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# -----------------------------------------------------------------------------
# Vision / AI (use one or the other depending on VISION_PROVIDER)
# -----------------------------------------------------------------------------
VISION_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
# OPENAI_API_KEY=your_openai_api_key

# After image extraction, fetch exact product name and full listing from the web (Gemini + Google Search).
# Set to false to use image-only extraction. Requires GEMINI_API_KEY; may incur extra cost for grounded queries.
# ENABLE_WEB_ENRICHMENT=true

# Optional: Google Cloud Vision for OCR (label text → material)
# GCP_VISION_CREDENTIALS_JSON=

# -----------------------------------------------------------------------------
# Redis (production Redis for Celery / background tasks)
# -----------------------------------------------------------------------------
REDIS_URL=redis://:password@your-redis-host:6379/0

# -----------------------------------------------------------------------------
# Clerk (JWT verification for API – match frontend app)
# From https://dashboard.clerk.com
# -----------------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx

# -----------------------------------------------------------------------------
# CORS – allowed origins for your frontend (comma-separated)
# Production: set to your frontend URL(s). Leave empty or * for allow-all (dev).
# For local dev (e.g. frontend on http://localhost:3000), use empty or * or add http://localhost:3000.
# -----------------------------------------------------------------------------
# Local dev (uncomment one of these if you get "Couldn't reach the server" on scan):
# CORS_ORIGINS=
# CORS_ORIGINS=http://localhost:3000
CORS_ORIGINS=https://synclyst.app,https://www.synclyst.app

# -----------------------------------------------------------------------------
# Optional: path to JSON file with known brands for logo/label matching
# BRANDS_DB_PATH=
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Shopify OAuth (required for Connect Shopify in the app)
# Create an app at https://partners.shopify.com, get Client ID and Client secret.
# Without these, the install endpoint returns "Shopify app not configured".
# APP_BASE_URL=https://api.yourdomain.com
# FRONTEND_URL=https://app.yourdomain.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# -----------------------------------------------------------------------------
# Integrations: webhook secret for listing-published (optional)
# Set to verify POST /api/v1/integrations/webhooks/listing-published
# -----------------------------------------------------------------------------
# INTEGRATIONS_WEBHOOK_SECRET=
# -----------------------------------------------------------------------------
